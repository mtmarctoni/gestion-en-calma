---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['finalCta'];
}

const { data } = Astro.props;
---

<section class="relative py-32 md:py-40 overflow-hidden">
  <!-- Full-bleed background image - calming nature/workspace -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1449247709967-d4461a6a6103?w=1920&q=80" 
      alt="Espacio tranquilo y natural" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-brand-terracotta/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-terracotta/60 via-transparent to-brand-terracotta/30"></div>
  </div>

  <!-- Floating organic shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[20%] left-[10%] w-[300px] h-[300px] bg-white/10 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-[20%] right-[10%] w-[400px] h-[400px] bg-brand-blush/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 3s;"></div>
  </div>

  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      {/* Icon */}
      <div class="w-20 h-20 mx-auto mb-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
        <svg class="w-10 h-10 text-white" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="24" cy="24" r="20"/>
          <path d="M14 24l6 6 12-12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
        {data.title}
      </h2>
      
      <p class="text-xl md:text-2xl text-white/90 mb-12 max-w-2xl mx-auto leading-relaxed">
        {data.body}
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <Button href={data.primaryCta.href} class="text-lg px-10 py-5 bg-white text-brand-terracotta hover:bg-brand-secondary shadow-warm">
          {data.primaryCta.label}
        </Button>
        <Button href={data.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer" class="text-lg px-10 py-5 border-white/40 text-white hover:bg-white/10">
          {data.secondaryCta.label}
        </Button>
      </div>
      
      {/* Trust indicators */}
      <div class="mt-12 flex flex-wrap justify-center gap-8 text-white/80">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Sin compromiso</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Respuesta en 24h</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Primera consulta gratis</span>
        </div>
      </div>
    </div>
  </Container>

  <style>
    @keyframes pulse-slow {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.05); opacity: 0.8; }
    }
    
    .animate-pulse-slow {
      animation: pulse-slow 8s ease-in-out infinite;
    }
  </style>
</section>
