---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['finalCta'];
}

const { data } = Astro.props;
---

<section class="relative py-20 md:py-28 overflow-hidden">
  <!-- Rich, multi-layered calming background -->
  <div class="absolute inset-0">
    <!-- Soft gradient base -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-secondary/40 via-brand-blush/30 to-brand-olive/20"></div>
    
    <!-- Floating organic shapes -->
    <div class="absolute top-[-10%] left-[-5%] w-[50vw] h-[50vw] rounded-full bg-brand-blush/30 blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-brand-teal/20 blur-3xl animate-float-slow" style="animation-delay: 3s;"></div>
    <div class="absolute top-[40%] right-[20%] w-[30vw] h-[30vw] rounded-full bg-brand-terracotta/15 blur-3xl animate-float-slow" style="animation-delay: 6s;"></div>
    
    <!-- Botanical decoration -->
    <svg class="absolute bottom-0 left-0 w-full h-48 text-brand-olive/15" viewBox="0 0 1440 200" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0,100 C240,50 480,150 720,100 C960,50 1200,150 1440,100 L1440,200 L0,200 Z"/>
    </svg>
  </div>

  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Decorative element above title -->
      <div class="w-20 h-20 mx-auto mb-8 rounded-full bg-white/50 backdrop-blur-sm flex items-center justify-center shadow-soft">
        <svg class="w-12 h-12 text-brand-terracotta" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M24 8 C30 15, 38 20, 38 30 C38 38, 32 42, 24 42 C16 42, 10 38, 10 30 C10 20, 18 15, 24 8" fill="currentColor" fill-opacity="0.2"/>
          <path d="M18 28 L22 32 L32 22" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      
      <h2 class="text-4xl md:text-6xl font-bold text-brand-text mb-6 leading-tight">
        {data.title}
      </h2>
      
      <p class="text-xl md:text-2xl text-brand-text-soft mb-12 max-w-2xl mx-auto leading-relaxed">
        {data.body}
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <Button href={data.primaryCta.href} class="text-lg px-10 py-5 shadow-warm">
          {data.primaryCta.label}
        </Button>
        <Button href={data.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer" class="text-lg px-10 py-5">
          {data.secondaryCta.label}
        </Button>
      </div>
      
      <!-- Trust indicators -->
      <div class="mt-12 flex flex-wrap justify-center gap-8 text-brand-text-muted">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Sin compromiso</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Respuesta en 24h</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-sm font-bold">Primera consulta gratis</span>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  @keyframes float-slow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.02); }
    66% { transform: translate(-20px, 20px) scale(0.98); }
  }
  
  .animate-float-slow {
    animation: float-slow 15s ease-in-out infinite;
  }
</style>
