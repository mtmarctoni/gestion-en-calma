---
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['process'];
}

const { data } = Astro.props;

// Step images - showing the process visually
const stepImages = [
  "https://images.unsplash.com/photo-1577563908411-5077b6dc7624?w=400&q=80", // Contact/Chat
  "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&q=80", // Analysis
  "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&q=80", // Organization
  "https://images.unsplash.com/photo-1493934558415-9d19f0b2b4d2?w=400&q=80", // Growth
];

const stepColors = [
  { bg: 'bg-brand-teal', border: 'border-brand-teal/20' },
  { bg: 'bg-brand-olive', border: 'border-brand-olive/20' },
  { bg: 'bg-brand-terracotta', border: 'border-brand-terracotta/20' },
  { bg: 'bg-brand-blush-deep', border: 'border-brand-blush-deep/30' },
];
---

<section class="relative py-24 md:py-32 overflow-hidden bg-brand-background">
  <!-- Soft background -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-secondary/20 via-brand-background to-brand-olive/5"></div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-20">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-primary/15 text-brand-primary text-xs font-bold tracking-wider uppercase">
        Cómo trabajo
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text">{data.title}</h2>
    </div>

    <!-- Process steps with images -->
    <div class="grid gap-8 lg:grid-cols-4">
      {data.steps.map((step, index) => (
        <div class="relative">
          {/* Connection line for desktop */}
          {index < data.steps.length - 1 && (
            <div class="hidden lg:block absolute top-24 left-1/2 w-full h-0.5 bg-gradient-to-r from-brand-secondary to-brand-olive/30"></div>
          )}
          
          <div class="bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300 border-2 {stepColors[index % 4].border}">
            {/* Step image */}
            <div class="relative h-40 overflow-hidden">
              <img 
                src={stepImages[index]} 
                alt={`Paso ${index + 1}: ${step.title}`}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
              
              {/* Step number overlay */}
              <div class={`absolute bottom-4 left-4 w-12 h-12 rounded-full ${stepColors[index % 4].bg} text-white flex items-center justify-center text-xl font-bold shadow-lg`}>
                {index + 1}
              </div>
            </div>
            
            {/* Content */}
            <div class="p-6 text-center">
              <h3 class="text-lg font-bold text-brand-text mb-2">{step.title}</h3>
              <p class="text-sm text-brand-text-soft leading-relaxed">{step.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
