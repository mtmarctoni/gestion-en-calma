---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, intro, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'mx-auto text-center' : 'text-left';
---

<div class={`max-w-3xl ${alignment}`.trim()}>
  {eyebrow && (
    <p class="mb-4 text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-brand-coffee/80">{eyebrow}</p>
  )}
  <h2 class="font-display text-balance text-[2.15rem] leading-tight text-brand-ink md:text-[2.85rem]">{title}</h2>
  {intro && <p class="mt-5 max-w-2xl text-pretty text-base leading-8 text-brand-ink-soft md:text-lg">{intro}</p>}
</div>
