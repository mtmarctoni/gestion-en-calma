---
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['painPoints'];
}

const { data } = Astro.props;

// Relatable images showing the problems
const painImages = [
  "https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=600&q=80", // Overwhelmed desk
  "https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=600&q=80", // Clock/time
  "https://images.unsplash.com/photo-1484480974693-6ca0a78fb36b?w=600&q=80", // Messy organization
];
---

<section class="relative py-24 md:py-32 overflow-hidden bg-brand-teal/5">
  <!-- Decorative top wave -->
  <div class="absolute top-0 left-0 right-0 h-24 overflow-hidden">
    <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="w-full h-full text-brand-background" aria-hidden="true">
      <path fill="currentColor" d="M0,60 C360,100 720,0 1080,60 C1260,90 1380,40 1440,60 L1440,0 L0,0 Z"/>
    </svg>
  </div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-terracotta/15 text-brand-terracotta text-xs font-bold tracking-wider uppercase">
        ¿Te suena familiar?
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-4">{data.title}</h2>
      <p class="text-lg text-brand-text-soft">{data.intro}</p>
    </div>

    <!-- Pain points with images -->
    <div class="grid gap-8 md:grid-cols-3">
      {data.items.slice(0, 3).map((item, index) => (
        <div class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
          {/* Image */}
          <div class="relative h-48 overflow-hidden">
            <img 
              src={painImages[index]} 
              alt=""
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
            />
            <div class="absolute inset-0 bg-brand-terracotta/10 group-hover:bg-transparent transition-colors"></div>
          </div>
          
          {/* Content */}
          <div class="p-8 text-center">
            <p class="text-lg font-bold text-brand-text leading-relaxed">
              {item}
            </p>
          </div>
        </div>
      ))}
    </div>
    
    {/* Transition message */}
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-white shadow-soft">
        <div class="w-3 h-3 rounded-full bg-brand-olive animate-pulse"></div>
        <span class="text-brand-text font-bold">Hay otra forma de trabajar</span>
        <div class="w-3 h-3 rounded-full bg-brand-olive animate-pulse" style="animation-delay: 0.5s;"></div>
      </div>
    </div>
  </Container>
</section>
