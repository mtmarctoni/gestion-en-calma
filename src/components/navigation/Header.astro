---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { SiteSettings } from '@/data/fallbackContent';

interface Props {
  site: SiteSettings;
  pathname: string;
}

const { site, pathname } = Astro.props;
---

<header class="sticky top-0 z-40 px-3 pt-3">
  <Container>
    <div class="flex flex-col gap-4 rounded-2xl border-2 border-brand-primary/20 bg-brand-background/90 px-5 py-4 shadow-soft backdrop-blur-xl lg:flex-row lg:items-center lg:justify-between lg:px-6">
      <div>
        <a class="text-2xl font-bold leading-none text-brand-text md:text-3xl" href="/">{site.siteName}</a>
        <p class="mt-2 max-w-lg text-sm leading-6 text-brand-text-soft">{site.tagline}</p>
      </div>

      <div class="flex flex-col gap-4 lg:items-end">
        <nav aria-label="Principal">
          <ul class="flex flex-wrap items-center gap-2 text-sm font-bold">
            {site.navLinks.map((link) => (
              <li>
                <a
                  class:list={[
                    'rounded-full px-3 py-2 transition',
                    pathname === link.href
                      ? 'bg-brand-primary text-brand-text shadow-warm'
                      : 'text-brand-text-soft hover:bg-brand-secondary hover:text-brand-text',
                  ]}
                  href={link.href}
                  aria-current={pathname === link.href ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex flex-wrap gap-3">
          <Button href={site.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer">{site.secondaryCta.label}</Button>
          <Button href={site.primaryCta.href}>{site.primaryCta.label}</Button>
        </div>
      </div>
    </div>
  </Container>
</header>
