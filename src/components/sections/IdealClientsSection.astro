---
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['idealClients'];
}

const { data } = Astro.props;
---

<section class="py-14 md:py-20">
  <Container>
    <SectionHeading title={data.title} intro={data.intro} />

    <div class="mt-10 flex flex-wrap gap-3">
      {data.items.map((item) => (
        <span class="rounded-full border-2 border-brand-primary/30 bg-brand-secondary px-5 py-2.5 text-sm font-bold text-brand-text shadow-card hover:border-brand-primary hover:bg-brand-primary transition-colors cursor-default">
          {item}
        </span>
      ))}
    </div>
  </Container>
</section>
