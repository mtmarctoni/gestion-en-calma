---
import ServicesGridSection from '@/components/sections/ServicesGridSection.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadServices, loadServicesPage, loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const [site, page, services] = await Promise.all([loadSiteSettings(), loadServicesPage(), loadServices()]);

const metadata = buildMetadata({
  seo: page.seo,
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  <section class="pb-12 pt-16 md:pb-16 md:pt-20">
    <Container>
      <SectionHeading eyebrow={page.intro.eyebrow} title={page.intro.title} intro={page.intro.body} />

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {page.categories.map((category) => (
          <article class="surface-card p-6">
            <h2 class="text-xl font-bold text-brand-text">{category.title}</h2>
            <p class="mt-4 text-base leading-7 text-brand-text-soft">{category.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <ServicesGridSection title="Servicios disponibles" services={services} />
</BaseLayout>
