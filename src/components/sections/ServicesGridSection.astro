---
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { Service } from '@/data/fallbackContent';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  services: Service[];
}

const { eyebrow, title, intro, services } = Astro.props;
---

<section class="py-14 md:py-20">
  <Container>
    <SectionHeading eyebrow={eyebrow} title={title} intro={intro} />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {services.map((service) => (
        <article class="surface-card-soft flex h-full flex-col p-6 transition-all duration-200 hover:shadow-warm">
          <h3 class="text-xl font-bold text-brand-text">{service.title}</h3>
          <p class="mt-4 text-base leading-7 text-brand-text-soft">{service.shortDescription}</p>

          <ul class="mt-5 space-y-2 text-sm text-brand-text-soft">
            {service.outcomes.slice(0, 3).map((outcome) => (
              <li class="flex gap-3">
                <span class="mt-2 inline-flex h-2 w-2 rounded-full bg-brand-primary"></span>
                <span>{outcome}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-3">
            <a class="font-bold text-brand-warm transition hover:text-brand-text" href={`/servicios/${service.slug}/`}>
              Ver servicio →
            </a>
          </div>
        </article>
      ))}
    </div>
  </Container>
</section>
