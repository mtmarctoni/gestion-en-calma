---
import Container from '@/components/ui/Container.astro';
import type { SiteSettings } from '@/data/fallbackContent';

interface Props {
  site: SiteSettings;
}

const { site } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="mt-20 px-3 pb-8 pt-6">
  <Container>
    <div class="surface-card-deep px-6 py-10 md:px-10 md:py-12">
      <div class="grid gap-10 md:grid-cols-[1.3fr_1fr_1fr]">
        <div>
          <p class="text-2xl font-bold text-brand-text">{site.siteName}</p>
          <p class="mt-3 max-w-lg text-sm leading-7 text-brand-text-soft">{site.tagline}</p>
          <p class="mt-4 text-sm text-brand-text-muted">{site.location}</p>
        </div>

        <div>
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-brand-primary">Contacto</h2>
          <ul class="mt-4 space-y-3 text-sm text-brand-text-soft">
            <li><a class="font-semibold transition hover:text-brand-text" href={`mailto:${site.email}`}>{site.email}</a></li>
            <li><a class="font-semibold transition hover:text-brand-text" href={site.whatsappUrl} target="_blank" rel="noreferrer">WhatsApp</a></li>
            <li><a class="font-semibold transition hover:text-brand-text" href={site.instagramUrl} target="_blank" rel="noreferrer">Instagram</a></li>
          </ul>
        </div>

        <div>
          <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-brand-primary">Legal</h2>
          <ul class="mt-4 space-y-3 text-sm text-brand-text-soft">
            {site.legalLinks.map((link) => (
              <li><a class="font-semibold transition hover:text-brand-text" href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-10 border-t border-brand-primary/20 pt-6 text-sm text-brand-text-muted">
        <p>&copy; {year} {site.siteName}. Todos los derechos reservados.</p>
      </div>
    </div>
  </Container>
</footer>
