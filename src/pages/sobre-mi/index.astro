---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadAboutPage, loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const [site, page] = await Promise.all([loadSiteSettings(), loadAboutPage()]);

const metadata = buildMetadata({
  seo: page.seo,
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  <section class="pb-16 pt-16 md:pt-20">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <!-- Yellow dominant panel for founder -->
        <div class="surface-primary-panel p-8 relative overflow-hidden">
          <div class="absolute -right-10 -bottom-10 h-32 w-32 rounded-full bg-brand-warm/20 blur-2xl"></div>
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text/70">{site.founderName}</p>
          <p class="mt-4 text-3xl font-bold text-brand-text md:text-4xl">Más de diez años de experiencia sosteniendo procesos que necesitan orden y seguimiento</p>
          <p class="mt-4 text-base leading-7 text-brand-text/80">Una forma de trabajar cercana, clara y muy orientada a que el negocio respire mejor.</p>
        </div>

        <div>
          <SectionHeading eyebrow={page.eyebrow} title={page.title} intro={page.intro} />
          <div class="mt-6 space-y-5 text-base leading-8 text-brand-text-soft">
            {page.story.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="pb-16">
    <Container>
      <div class="grid gap-5 md:grid-cols-3">
        {page.values.map((value) => (
          <article class="surface-card p-6">
            <h2 class="text-xl font-bold text-brand-text">{value.title}</h2>
            <p class="mt-4 text-base leading-7 text-brand-text-soft">{value.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="pb-20">
    <Container>
      <div class="surface-primary-panel px-8 py-10 relative overflow-hidden">
        <div class="absolute -left-10 -top-10 h-40 w-40 rounded-full bg-brand-soft/20 blur-3xl"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold text-brand-text md:text-4xl">Si te reconoces en esta forma de trabajar, podemos hablar</h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-brand-text/80">No hace falta tenerlo todo claro antes de contactar. A veces lo primero es simplemente poner nombre a lo que hoy te está pesando.</p>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/contacto/">Contactar</Button>
            <Button href={site.whatsappUrl} variant="secondary" target="_blank" rel="noreferrer">WhatsApp</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
