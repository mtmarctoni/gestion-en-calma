---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['founder'];
}

const { data } = Astro.props;
---

<section class="bg-brand-secondary/20 py-14 md:py-20">
  <Container>
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <!-- Founder card - warm yellow panel -->
      <div class="surface-primary-panel p-8">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text/70">Yolanda</p>
        <p class="mt-4 text-3xl font-bold text-brand-text md:text-4xl">Apoyo cercano, criterio y seguimiento real</p>
        <p class="mt-4 text-base leading-7 text-brand-text/80">Una presencia tranquila que ayuda a que el negocio no dependa siempre de la misma persona.</p>
      </div>

      <div>
        <SectionHeading eyebrow="Sobre mí" title={data.title} />
        <div class="mt-6 space-y-5 text-base leading-8 text-brand-text-soft">
          {data.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="mt-8">
          <Button href="/sobre-mi/" variant="secondary">Conocer más sobre Yolanda</Button>
        </div>
      </div>
    </div>
  </Container>
</section>
