---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadAboutPage, loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const [site, page] = await Promise.all([loadSiteSettings(), loadAboutPage()]);

const metadata = buildMetadata({
  seo: page.seo,
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  {/* Hero section with image - more visual and warm */}
  <section class="relative py-16 md:py-24 overflow-hidden">
    {/* Background decoration */}
    <div class="absolute inset-0 bg-gradient-to-br from-brand-blush/20 via-transparent to-brand-teal/10"></div>
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-brand-olive/5 to-transparent"></div>
    
    <Container class="relative z-10">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        {/* Left - Founder portrait */}
        <div class="relative">
          <div class="relative max-w-lg mx-auto lg:mx-0">
            {/* Main image */}
            <div class="relative aspect-[4/5] rounded-3xl overflow-hidden shadow-2xl">
              <img 
                src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=80" 
                alt={`${site.founderName} - Fundadora de Gestión en Calma`}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-terracotta/20 via-transparent to-transparent"></div>
            </div>
            
            {/* Floating accent card */}
            <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl p-6 shadow-xl border border-brand-secondary/20 max-w-[200px]">
              <p class="text-3xl font-bold text-brand-terracotta">10+</p>
              <p class="text-sm text-brand-text-soft mt-1">años de experiencia</p>
            </div>
            
            {/* Decorative elements */}
            <div class="absolute -top-4 -left-4 w-24 h-24 bg-brand-blush/40 rounded-full blur-xl"></div>
            <div class="absolute top-1/2 -left-8 w-16 h-16 bg-brand-olive/20 rounded-full blur-lg"></div>
          </div>
        </div>

        {/* Right - Content */}
        <div class="lg:pl-8">
          <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-teal/15 text-brand-teal text-xs font-bold tracking-wider uppercase">
            {page.eyebrow}
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text leading-tight mb-6">
            {page.title}
          </h1>
          <p class="text-xl text-brand-text-soft leading-relaxed mb-8">
            {page.intro}
          </p>
          <div class="space-y-5 text-base leading-8 text-brand-text-soft">
            {page.story.slice(0, 2).map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </div>
      </div>
    </Container>
  </section>

  {/* Values section with icons and images */}
  <section class="py-16 md:py-24 bg-brand-teal/5">
    <Container>
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-olive/15 text-brand-olive text-xs font-bold tracking-wider uppercase">
          Valores
        </span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-brand-text">Cómo trabajo</h2>
      </div>
      
      <div class="grid gap-8 md:grid-cols-3">
        {page.values.map((value, index) => {
          const valueImages = [
            "https://images.unsplash.com/photo-1521791136064-7986c2920216?w=600&q=80", // Cercanía - handshake
            "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&q=80", // Orden - documents
            "https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80", // Confianza - teamwork
          ];
          const valueIcons = [
            `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
            `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>`,
            `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>`,
          ];
          const cardColors = ['bg-brand-olive', 'bg-brand-teal', 'bg-brand-terracotta'];
          return (
            <article class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
              {/* Image */}
              <div class="relative h-48 overflow-hidden">
                <img 
                  src={valueImages[index]} 
                  alt={value.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                {/* Icon badge */}
                <div class={`absolute bottom-4 left-4 w-12 h-12 rounded-full ${cardColors[index]} text-white flex items-center justify-center shadow-lg`}>
                  <Fragment set:html={valueIcons[index]} />
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-brand-text mb-3">{value.title}</h3>
                <p class="text-brand-text-soft leading-relaxed">{value.description}</p>
              </div>
            </article>
          );
        })}
      </div>
    </Container>
  </section>

  {/* Story continuation with image */}
  <section class="py-16 md:py-24">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="order-2 lg:order-1">
          <div class="space-y-5 text-base leading-8 text-brand-text-soft">
            {page.story.slice(2).map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/contacto/">Contactar</Button>
            <Button href="/servicios/" variant="secondary">Ver servicios</Button>
          </div>
        </div>
        
        <div class="order-1 lg:order-2 relative">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80" 
              alt="Espacio de trabajo tranquilo"
              class="w-full aspect-[4/3] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-terracotta/10 to-transparent"></div>
          </div>
          {/* Decorative blob */}
          <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-brand-blush/50 rounded-full blur-2xl"></div>
        </div>
      </div>
    </Container>
  </section>

  {/* Final CTA - more visual */}
  <section class="pb-20">
    <Container>
      <div class="relative rounded-3xl overflow-hidden">
        {/* Background image */}
        <div class="absolute inset-0">
          <img 
            src="https://images.unsplash.com/photo-1449247709967-d4461a6a6103?w=1920&q=80" 
            alt="" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-brand-terracotta/60"></div>
        </div>
        
        <div class="relative z-10 px-8 py-16 md:px-16 md:py-20 text-center">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">Si te reconoces en esta forma de trabajar, podemos hablar</h2>
          <p class="mt-4 max-w-2xl mx-auto text-lg text-white/90 leading-relaxed">No hace falta tenerlo todo claro antes de contactar. A veces lo primero es simplemente poner nombre a lo que hoy te está pesando.</p>
          <div class="mt-8 flex flex-wrap justify-center gap-4">
            <Button href="/contacto/" class="bg-white text-brand-terracotta hover:bg-brand-secondary">Contactar</Button>
            <Button href={site.whatsappUrl} variant="secondary" target="_blank" rel="noreferrer" class="border-white/40 text-white hover:bg-white/10">WhatsApp</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
