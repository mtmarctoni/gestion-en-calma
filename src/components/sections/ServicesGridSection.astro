---
import Container from '@/components/ui/Container.astro';
import type { Service } from '@/data/fallbackContent';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  services: Service[];
}

const { eyebrow, title, intro, services } = Astro.props;

// Service images - calming work scenes
const serviceImages = [
  "https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=600&q=80", // Organización
  "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?w=600&q=80", // Digital
  "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=600&q=80", // Finanzas
  "https://images.unsplash.com/photo-1517842645767-c639042777db?w=600&q=80", // Documentación
];

const cardColors = [
  { accent: 'bg-brand-olive', text: 'text-brand-olive' },
  { accent: 'bg-brand-teal', text: 'text-brand-teal' },
  { accent: 'bg-brand-terracotta', text: 'text-brand-terracotta' },
  { accent: 'bg-brand-blush-deep', text: 'text-brand-blush-deep' },
];
---

<section class="relative py-24 md:py-32 overflow-hidden bg-brand-background">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-30">
    <img 
      src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1920&q=80" 
      alt="" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-brand-background/90"></div>
  </div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      {eyebrow && (
        <span class="inline-block mb-4 px-4 py-2 rounded-full bg-white shadow-sm text-brand-olive text-xs font-bold tracking-wider uppercase">
          {eyebrow}
        </span>
      )}
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-4">{title}</h2>
      {intro && <p class="text-lg text-brand-text-soft">{intro}</p>}
    </div>

    <!-- Services grid with images -->
    <div class="grid gap-8 md:grid-cols-2">
      {services.map((service, index) => (
        <a 
          href={`/servicios/${service.slug}/`}
          class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300 flex flex-col"
        >
          <!-- Image -->
          <div class="relative h-48 md:h-56 overflow-hidden">
            <img 
              src={serviceImages[index % 4]} 
              alt={service.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            
            <!-- Service number badge -->
            <div class={`absolute top-4 left-4 w-10 h-10 rounded-full ${cardColors[index % 4].accent} text-white flex items-center justify-center font-bold shadow-lg`}>
              {index + 1}
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-6 md:p-8 flex-grow flex flex-col">
            <h3 class="text-xl md:text-2xl font-bold text-brand-text mb-3 group-hover:text-brand-terracotta transition-colors">
              {service.title}
            </h3>
            
            <p class="text-brand-text-soft leading-relaxed mb-6 flex-grow">
              {service.shortDescription}
            </p>
            
            <!-- Learn more link -->
            <div class="flex items-center gap-2 font-bold text-brand-terracotta group-hover:translate-x-2 transition-transform">
              Saber más 
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
