---
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { FAQItem } from '@/data/fallbackContent';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<section class="py-14 md:py-20">
  <Container>
    <SectionHeading eyebrow="Preguntas frecuentes" title="Respuestas rápidas antes de hablar" />

    <div class="mt-10 space-y-4">
      {items.map((item) => (
        <details class="surface-card px-6 py-5 cursor-pointer transition-all hover:shadow-warm">
          <summary class="list-none font-bold text-brand-text flex items-center justify-between">
            {item.question}
            <span class="faq-icon text-brand-primary text-xl font-bold">+</span>
          </summary>
          <p class="mt-4 max-w-3xl text-base leading-7 text-brand-text-soft">{item.answer}</p>
        </details>
      ))}
    </div>
  </Container>
</section>
