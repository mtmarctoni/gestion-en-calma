---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  hero: HomePageData['hero'];
}

const { hero } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-background min-h-[90vh] flex items-center">
  <!-- Animated background with calming organic shapes -->
  <div class="absolute inset-0 overflow-hidden">
    <!-- Large soft organic blobs -->
    <div class="absolute top-[-10%] right-[-5%] w-[60vw] h-[60vw] rounded-full bg-gradient-to-br from-brand-blush/40 via-brand-secondary/30 to-transparent blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-gradient-to-tr from-brand-teal/25 via-brand-olive/20 to-transparent blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute top-[40%] left-[20%] w-[30vw] h-[30vw] rounded-full bg-gradient-to-br from-brand-terracotta/15 to-transparent blur-3xl animate-pulse-slow" style="animation-delay: 4s;"></div>
    
    <!-- Botanical SVG decoration - eucalyptus/wildflowers -->
    <svg class="absolute bottom-0 left-0 w-full h-32 text-brand-olive/20" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0,80 Q360,40 720,70 T1440,60 L1440,120 L0,120 Z" />
    </svg>
    
    <!-- Floating botanical elements -->
    <svg class="absolute top-[20%] left-[5%] w-24 h-24 text-brand-olive/30 animate-float" viewBox="0 0 100 100" aria-hidden="true">
      <circle cx="50" cy="50" r="40" fill="none" stroke="currentColor" stroke-width="0.5" />
      <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="0.5" />
      <circle cx="50" cy="50" r="20" fill="none" stroke="currentColor" stroke-width="0.5" />
    </svg>
    
    <svg class="absolute top-[60%] right-[8%] w-32 h-32 text-brand-teal/25 animate-float" style="animation-delay: 1.5s;" viewBox="0 0 100 100" aria-hidden="true">
      <path fill="currentColor" d="M50,10 C70,10 85,25 85,50 C85,75 70,90 50,90 C30,90 15,75 15,50 C15,25 30,10 50,10 Z M50,25 C60,25 70,35 70,50 C70,65 60,75 50,75 C40,75 30,65 30,50 C30,35 40,25 50,25 Z" />
    </svg>
    
    <svg class="absolute bottom-[30%] left-[15%] w-20 h-20 text-brand-terracotta/20 animate-float" style="animation-delay: 3s;" viewBox="0 0 100 100" aria-hidden="true">
      <ellipse cx="50" cy="50" rx="45" ry="35" fill="none" stroke="currentColor" stroke-width="1" />
      <ellipse cx="50" cy="50" rx="30" ry="25" fill="none" stroke="currentColor" stroke-width="1" />
    </svg>
  </div>

  <Container class="relative z-10">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <!-- Text content - minimal and impactful -->
      <div class="max-w-xl">
        <span class="inline-block mb-6 px-4 py-2 rounded-full bg-brand-blush/50 text-brand-text-soft text-xs font-bold tracking-wider uppercase">
          {hero.eyebrow}
        </span>
        
        <h1 class="text-balance text-5xl leading-[1.1] text-brand-text md:text-6xl lg:text-7xl font-bold mb-8">
          {hero.title}
        </h1>
        
        <p class="text-pretty text-xl leading-relaxed text-brand-text-soft mb-10 max-w-lg">
          {hero.subtitle}
        </p>

        <div class="flex flex-wrap gap-4">
          <Button href={hero.primaryCta.href} class="text-lg px-8 py-4">{hero.primaryCta.label}</Button>
          <Button href={hero.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer" class="text-lg px-8 py-4">
            {hero.secondaryCta.label}
          </Button>
        </div>
      </div>

      <!-- Visual element - Calm workspace illustration -->
      <div class="relative hidden lg:block">
        <div class="relative aspect-square max-w-lg mx-auto">
          <!-- Main circular frame with calming image placeholder -->
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-brand-secondary via-brand-blush to-brand-olive/30 p-2">
            <div class="w-full h-full rounded-full overflow-hidden bg-brand-background relative">
              <!-- Placeholder calm workspace/nature scene -->
              <div class="absolute inset-0 bg-gradient-to-br from-brand-background via-brand-secondary/50 to-brand-blush/50 flex items-center justify-center">
                <!-- SVG illustration of calm workspace with plants -->
                <svg class="w-3/4 h-3/4 text-brand-olive/40" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <!-- Table -->
                  <rect x="20" y="140" width="160" height="10" rx="2" fill="currentColor" fill-opacity="0.3"/>
                  <rect x="30" y="150" width="8" height="40" rx="1" fill="currentColor" fill-opacity="0.2"/>
                  <rect x="162" y="150" width="8" height="40" rx="1" fill="currentColor" fill-opacity="0.2"/>
                  
                  <!-- Plant pot -->
                  <path d="M80 140 L85 110 H115 L120 140 Z" fill="currentColor" fill-opacity="0.4"/>
                  <ellipse cx="100" cy="110" rx="15" ry="5" fill="currentColor" fill-opacity="0.5"/>
                  
                  <!-- Plant leaves -->
                  <path d="M100 110 Q90 80 70 70 Q85 85 100 110" fill="currentColor" fill-opacity="0.3"/>
                  <path d="M100 110 Q110 75 130 65 Q115 80 100 110" fill="currentColor" fill-opacity="0.35"/>
                  <path d="M100 110 Q100 60 100 50 Q100 70 100 110" fill="currentColor" fill-opacity="0.4"/>
                  <path d="M100 110 Q85 90 60 95 Q80 95 100 110" fill="currentColor" fill-opacity="0.25"/>
                  <path d="M100 110 Q115 90 140 95 Q120 95 100 110" fill="currentColor" fill-opacity="0.3"/>
                  
                  <!-- Coffee cup -->
                  <rect x="130" y="120" width="20" height="18" rx="2" fill="currentColor" fill-opacity="0.3"/>
                  <path d="M152 125 Q158 125 158 130 Q158 135 152 135" stroke="currentColor" stroke-width="2" stroke-opacity="0.4" fill="none"/>
                  <path d="M135 118 Q140 115 145 118" stroke="currentColor" stroke-width="1" stroke-opacity="0.3" fill="none"/>
                  
                  <!-- Notebook -->
                  <rect x="45" y="125" width="25" height="12" rx="1" fill="currentColor" fill-opacity="0.2"/>
                  <line x1="48" y1="128" x2="67" y2="128" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
                  <line x1="48" y1="131" x2="67" y2="131" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
                  <line x1="48" y1="134" x2="62" y2="134" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
                  
                  <!-- Decorative circles - calm bubbles -->
                  <circle cx="160" cy="60" r="15" fill="currentColor" fill-opacity="0.1"/>
                  <circle cx="40" cy="80" r="10" fill="currentColor" fill-opacity="0.15"/>
                  <circle cx="170" cy="100" r="8" fill="currentColor" fill-opacity="0.12"/>
                </svg>
              </div>
              
              <!-- Image placeholder text -->
              <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-center">
                <p class="text-xs text-brand-text-muted font-bold uppercase tracking-wider">Espacio de calma</p>
              </div>
            </div>
          </div>
          
          <!-- Decorative floating elements -->
          <div class="absolute -top-4 -right-4 w-24 h-24 rounded-full bg-brand-terracotta/20 blur-xl"></div>
          <div class="absolute -bottom-6 -left-6 w-32 h-32 rounded-full bg-brand-teal/15 blur-xl"></div>
          <div class="absolute top-1/2 -right-8 w-16 h-16 rounded-full bg-brand-primary/20 blur-lg"></div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.8; }
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(3deg); }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
