---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  target?: string;
  rel?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  target,
  rel,
  type = 'button',
  class: className = '',
} = Astro.props;

const baseClass =
  'inline-flex items-center justify-center rounded-full px-5 py-3.5 text-sm font-semibold tracking-[0.01em] transition duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-cream';

const variantClass = {
  primary:
    'bg-brand-olive-deep text-brand-paper shadow-[0_14px_28px_rgba(77,93,65,0.18)] hover:bg-brand-coffee focus-visible:ring-brand-olive',
  secondary:
    'border border-brand-olive/15 bg-brand-paper/80 text-brand-ink shadow-[0_10px_24px_rgba(74,56,37,0.08)] hover:border-brand-ochre/35 hover:bg-brand-paper focus-visible:ring-brand-ochre',
  ghost: 'text-brand-coffee hover:bg-brand-paper/70 hover:text-brand-ink focus-visible:ring-brand-ochre',
}[variant];

const classes = `${baseClass} ${variantClass} ${className}`.trim();
---

{href ? (
  <a class={classes} href={href} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={classes} type={type}>
    <slot />
  </button>
)}
