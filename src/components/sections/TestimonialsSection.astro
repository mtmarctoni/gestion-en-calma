---
import Container from '@/components/ui/Container.astro';
import type { Testimonial } from '@/data/fallbackContent';

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
const hasPublishedTestimonials = items.some((item) => !item.isPlaceholder);

// Real portrait photos for testimonials
const testimonialPhotos = [
  "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80",
  "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&q=80",
  "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&q=80",
  "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80",
];
---

<section class="relative py-24 md:py-32 overflow-hidden">
  <!-- Background image - peaceful scene -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?w=1920&q=80" 
      alt="" 
      class="w-full h-full object-cover opacity-10"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-background via-brand-background/95 to-brand-background"></div>
  </div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-olive/15 text-brand-olive text-xs font-bold tracking-wider uppercase">
        Confianza
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-4">
        {hasPublishedTestimonials ? 'Testimonios' : 'Experiencia'}
      </h2>
      <p class="text-lg text-brand-text-soft">
        {hasPublishedTestimonials
          ? 'Lo que dicen quienes han trabajado con Gestión en Calma'
          : 'Compromiso real con cada proyecto'}
      </p>
    </div>

    <!-- Testimonials with real photos -->
    <div class="grid gap-8 lg:grid-cols-2">
      {items.map((item, index) => (
        <div class={`bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300 ${index % 2 === 0 ? 'lg:translate-y-8' : ''}`}>
          <div class="flex flex-col md:flex-row">
            {/* Portrait photo */}
            <div class="md:w-1/3 h-48 md:h-auto relative">
              <img 
                src={testimonialPhotos[index % 4]} 
                alt={item.name}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-transparent to-black/10 md:bg-gradient-to-l"></div>
            </div>
            
            {/* Quote content */}
            <div class="md:w-2/3 p-8 flex flex-col justify-center">
              <div class="text-4xl text-brand-olive/30 mb-4" aria-hidden="true">"</div>
              <blockquote>
                <p class="text-lg text-brand-text leading-relaxed mb-6">
                  {item.quote}
                </p>
              </blockquote>
              
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-brand-olive/10 flex items-center justify-center text-brand-olive font-bold">
                  {item.name.charAt(0)}
                </div>
                <div>
                  <p class="font-bold text-brand-text">{item.name}</p>
                  {item.role && <p class="text-sm text-brand-text-muted">{item.role}</p>}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    {/* Empty state - visual placeholder */}
    {!hasPublishedTestimonials && (
      <div class="mt-16 text-center">
        <div class="inline-flex flex-col items-center gap-4 px-8 py-6 rounded-3xl bg-white shadow-soft">
          <div class="w-16 h-16 rounded-full bg-brand-olive/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <p class="text-brand-text-soft">Próximamente compartiremos experiencias reales</p>
        </div>
      </div>
    )}
  </Container>
</section>
