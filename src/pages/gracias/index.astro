---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const site = await loadSiteSettings();

const metadata = buildMetadata({
  seo: {
    title: `Gracias | ${site.siteName}`,
    description: 'Tu mensaje ha sido enviado correctamente.',
    ogImage: site.seo.ogImage,
  },
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  <section class="py-24">
    <Container>
      <div class="mx-auto max-w-3xl rounded-[2rem] border border-brand-olive/10 bg-brand-paper p-10 text-center shadow-[0_20px_50px_rgba(74,86,57,0.04)]">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-olive-deep/80">Mensaje enviado</p>
        <h1 class="mt-4 font-display text-5xl text-brand-ink">Gracias por escribir</h1>
        <p class="mt-6 text-base leading-8 text-brand-ink-soft">Tu mensaje ha salido bien. Yolanda podrá revisarlo y responderte por email lo antes posible.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <Button href="/">Volver al inicio</Button>
          <Button href={site.whatsappUrl} variant="secondary" target="_blank" rel="noreferrer">Abrir WhatsApp</Button>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
