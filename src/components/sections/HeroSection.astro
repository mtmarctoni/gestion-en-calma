---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  hero: HomePageData['hero'];
}

const { hero } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-background pb-16 pt-14 md:pb-24 md:pt-20">
  <!-- Warm decorative blobs -->
  <div class="absolute inset-x-0 top-0 -z-10 h-full">
    <div class="absolute right-0 top-0 h-[500px] w-[500px] translate-x-1/4 -translate-y-1/4 rounded-full bg-brand-primary/20 blur-3xl"></div>
    <div class="absolute left-0 top-1/4 h-[400px] w-[400px] -translate-x-1/4 rounded-full bg-brand-warm/15 blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 h-[300px] w-[300px] rounded-full bg-brand-soft/20 blur-3xl"></div>
  </div>

  <Container>
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div>
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.3em] text-brand-primary">{hero.eyebrow}</p>
        <h1 class="max-w-4xl text-balance text-4xl leading-tight text-brand-text md:text-5xl lg:text-6xl font-bold">{hero.title}</h1>
        <p class="mt-6 max-w-2xl text-pretty text-lg leading-8 text-brand-text-soft md:text-xl">{hero.subtitle}</p>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={hero.primaryCta.href}>{hero.primaryCta.label}</Button>
          <Button href={hero.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer">{hero.secondaryCta.label}</Button>
        </div>
      </div>

      <!-- Idea card - warm yellow dominant -->
      <div class="surface-primary-panel p-8">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-brand-text/70">La idea</p>
        <p class="mt-5 text-2xl leading-tight text-brand-text font-bold md:text-3xl">Menos ruido operativo. Más espacio para llevar tu negocio con claridad.</p>
        <p class="mt-5 text-base leading-7 text-brand-text/80">
          Cuando la gestión diaria pesa demasiado, todo se vuelve más lento. Esta web está pensada para transmitir justo lo contrario: apoyo cercano, orden útil y tranquilidad.
        </p>
      </div>
    </div>
  </Container>
</section>
