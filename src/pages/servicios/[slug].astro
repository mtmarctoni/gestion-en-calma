---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { servicesFallback } from '@/data/fallbackContent';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadServiceBySlug, loadServices, loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

export async function getStaticPaths() {
  const services = await loadServices();

  return services.map((service) => ({
    params: { slug: service.slug },
  }));
}

const { slug } = Astro.params;
const [site, service] = await Promise.all([loadSiteSettings(), loadServiceBySlug(slug ?? '')]);

if (!service) {
  return Astro.redirect('/servicios/');
}

const metadata = buildMetadata({
  seo: {
    title: `${service.title} | ${site.siteName}`,
    description: service.shortDescription,
    ogImage: site.seo.ogImage,
  },
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});

const relatedServices = servicesFallback.filter((item) => item.slug !== service.slug).slice(0, 3);
---

<BaseLayout site={site} metadata={metadata}>
  <section class="pb-16 pt-16 md:pt-20">
    <Container>
      <a class="text-sm font-bold text-brand-warm hover:text-brand-text" href="/servicios/">← Volver a servicios</a>

      <div class="mt-8 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-primary">Servicio</p>
          <h1 class="mt-4 max-w-3xl text-balance text-4xl font-bold leading-tight text-brand-text md:text-5xl">{service.title}</h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-brand-text-soft">{service.shortDescription}</p>

          {service.longDescription && <p class="mt-8 text-base leading-8 text-brand-text-soft">{service.longDescription}</p>}

          <div class="mt-10 flex flex-wrap gap-4">
            <Button href="/contacto/">Hablar con Yolanda</Button>
            <Button href={site.whatsappUrl} variant="secondary" target="_blank" rel="noreferrer">Escribir por WhatsApp</Button>
          </div>
        </div>

        <aside class="surface-card-soft p-8">
          <h2 class="text-xl font-bold text-brand-text md:text-2xl">¿Qué puede aportar este servicio?</h2>
          <ul class="mt-6 space-y-4 text-base leading-7 text-brand-text-soft">
            {service.outcomes.map((outcome) => (
              <li class="flex gap-3">
                <span class="mt-2 inline-flex h-2.5 w-2.5 rounded-full bg-brand-primary"></span>
                <span>{outcome}</span>
              </li>
            ))}
          </ul>

          <h3 class="mt-8 text-lg font-bold text-brand-text md:text-xl">¿Qué incluye normalmente?</h3>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-brand-text-soft">
            {service.deliverables.map((deliverable) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brand-warm"></span>
                {deliverable}
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </Container>
  </section>

  <section class="pb-18">
    <Container>
      <div class="surface-card p-8">
        <h2 class="text-2xl font-bold text-brand-text md:text-3xl">Otros servicios relacionados</h2>
        <div class="mt-8 grid gap-5 md:grid-cols-3">
          {relatedServices.map((item) => (
            <article class="surface-card-soft p-5">
              <h3 class="text-lg font-bold text-brand-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-brand-text-soft">{item.shortDescription}</p>
              <a class="mt-5 inline-block font-bold text-brand-warm hover:text-brand-text" href={`/servicios/${item.slug}/`}>
                Ver más →
              </a>
            </article>
          ))}
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
