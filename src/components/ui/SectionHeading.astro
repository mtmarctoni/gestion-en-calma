---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, intro, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'mx-auto text-center' : 'text-left';
---

<div class={`max-w-3xl ${alignment}`.trim()}>
  {eyebrow && (
    <p class="mb-4 text-xs font-bold uppercase tracking-[0.3em] text-brand-primary">{eyebrow}</p>
  )}
  <h2 class="text-balance text-2xl font-bold leading-tight text-brand-text md:text-3xl lg:text-4xl">{title}</h2>
  {intro && <p class="mt-5 max-w-2xl text-pretty text-base leading-8 text-brand-text-soft md:text-lg">{intro}</p>}
</div>
