---
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['process'];
}

const { data } = Astro.props;
---

<section class="py-14 md:py-20">
  <Container>
    <SectionHeading title={data.title} />

    <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {data.steps.map((step, index) => (
        <article class="surface-card p-6 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 h-20 w-20 rounded-full bg-brand-primary/10"></div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-primary">Paso {index + 1}</p>
          <h3 class="mt-4 text-xl font-bold text-brand-text">{step.title}</h3>
          <p class="mt-4 text-base leading-7 text-brand-text-soft">{step.description}</p>
        </article>
      ))}
    </div>
  </Container>
</section>
