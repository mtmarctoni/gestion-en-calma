---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  hero: HomePageData['hero'];
}

const { hero } = Astro.props;
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-brand-background">
  <!-- Background image - peaceful workspace/nature -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1920&q=80" 
      alt="" 
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-background via-brand-background/95 to-brand-background/70"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-brand-background"></div>
  </div>

  <!-- Animated organic blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] bg-brand-blush/30 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-[20%] left-[-5%] w-[400px] h-[400px] bg-brand-teal/20 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
  </div>

  <Container class="relative z-10 py-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text content -->
      <div class="max-w-xl">
        <span class="inline-block mb-6 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm text-brand-terracotta text-xs font-bold tracking-wider uppercase border border-brand-terracotta/20">
          {hero.eyebrow}
        </span>
        
        <h1 class="text-balance text-5xl leading-[1.1] text-brand-text md:text-6xl lg:text-7xl font-bold mb-8">
          {hero.title}
        </h1>
        
        <p class="text-pretty text-xl leading-relaxed text-brand-text-soft mb-10 max-w-lg">
          {hero.subtitle}
        </p>

        <div class="flex flex-wrap gap-4">
          <Button href={hero.primaryCta.href} class="text-lg px-8 py-4 shadow-warm">
            {hero.primaryCta.label}
          </Button>
          <Button href={hero.secondaryCta.href} variant="secondary" target="_blank" rel="noreferrer" class="text-lg px-8 py-4">
            {hero.secondaryCta.label}
          </Button>
        </div>
      </div>

      <!-- Hero image - calm workspace -->
      <div class="relative hidden lg:block">
        <div class="relative">
          <!-- Main image with botanical frame -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1513694203232-719a280e022f?w=800&q=80" 
              alt="Espacio de trabajo tranquilo con plantas y luz natural"
              class="w-full aspect-[4/5] object-cover"
            />
            <!-- Soft overlay for text readability if needed -->
            <div class="absolute inset-0 bg-gradient-to-t from-brand-terracotta/10 to-transparent"></div>
          </div>
          
          <!-- Floating accent image - detail shot -->
          <div class="absolute -bottom-8 -left-8 w-48 h-48 rounded-2xl overflow-hidden shadow-xl border-4 border-white">
            <img 
              src="https://images.unsplash.com/photo-1507652313519-d4e9174996dd?w=400&q=80" 
              alt="Detalle de planta y organización"
              class="w-full h-full object-cover"
            />
          </div>
          
          <!-- Decorative elements -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-brand-terracotta/20 rounded-full blur-2xl"></div>
          <div class="absolute top-1/2 -right-12 w-24 h-24 bg-brand-teal/20 rounded-full blur-xl"></div>
        </div>
      </div>
    </div>
  </Container>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden lg:block">
    <div class="w-6 h-10 rounded-full border-2 border-brand-text/20 flex items-start justify-center p-2">
      <div class="w-1.5 h-2.5 bg-brand-terracotta rounded-full animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.8; }
  }
  
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
</style>
