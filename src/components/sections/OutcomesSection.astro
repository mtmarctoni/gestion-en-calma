---
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['outcomes'];
}

const { data } = Astro.props;

// Positive outcome images
const outcomeImages = [
  "https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=400&q=80", // Peace/meditation
  "https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=400&q=80", // Time/coffee
  "https://images.unsplash.com/photo-1449247709967-d4461a6a6103?w=400&q=80", // Growth/plant
  "https://images.unsplash.com/photo-1456324504439-367cee3b3c32?w=400&q=80", // Organized
  "https://images.unsplash.com/photo-1515023115689-589c33041d3c?w=400&q=80", // Balance
  "https://images.unsplash.com/photo-1517842645767-c639042777db?w=400&q=80", // Clarity/workspace
];
---

<section class="relative py-24 md:py-32 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1920&q=80" 
      alt="" 
      class="w-full h-full object-cover opacity-10"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-brand-background via-brand-terracotta/5 to-brand-background"></div>
  </div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-terracotta/15 text-brand-terracotta text-xs font-bold tracking-wider uppercase">
        Resultados
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text">{data.title}</h2>
    </div>

    <!-- Outcomes grid with images -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {data.items.map((item, index) => (
        <div class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
          {/* Image */}
          <div class="relative h-32 overflow-hidden">
            <img 
              src={outcomeImages[index % 6]} 
              alt=""
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            
            {/* Icon badge */}
            <div class="absolute bottom-4 left-4 w-10 h-10 rounded-full bg-white shadow-md flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-terracotta" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 13l4 4L19 7"/>
              </svg>
            </div>
          </div>
          
          {/* Content */}
          <div class="p-6">
            <p class="text-lg font-bold text-brand-text leading-snug">{item}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
