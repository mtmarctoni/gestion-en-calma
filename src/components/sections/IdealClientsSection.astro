---
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['idealClients'];
}

const { data } = Astro.props;

// Client type images - showing real work scenarios
const clientImages = [
  "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600&q=80", // Entrepreneur at laptop
  "https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80", // Small team
  "https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=600&q=80", // Freelancer workspace
  "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=600&q=80", // Business meeting
];

const cardColors = [
  { accent: 'bg-brand-olive', text: 'text-brand-olive' },
  { accent: 'bg-brand-teal', text: 'text-brand-teal' },
  { accent: 'bg-brand-terracotta', text: 'text-brand-terracotta' },
  { accent: 'bg-brand-blush-deep', text: 'text-brand-blush-deep' },
];
---

<section class="relative py-24 md:py-32 overflow-hidden bg-brand-background">
  <!-- Soft background -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-blush/10 to-transparent"></div>

  <Container class="relative z-10">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-blush/50 text-brand-blush-deep text-xs font-bold tracking-wider uppercase">
        Para quién
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-4">{data.title}</h2>
      <p class="text-lg text-brand-text-soft">{data.intro}</p>
    </div>

    {/* Client types with images */}
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {data.items.map((item, index) => (
        <div class="group relative rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
          {/* Image */}
          <div class="relative h-80">
            <img 
              src={clientImages[index % 4]} 
              alt={item}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
          </div>
          
          {/* Content overlay */}
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <div class={`inline-flex items-center justify-center w-12 h-12 rounded-full ${cardColors[index % 4].accent} text-white mb-4 shadow-lg`}>
              <span class="text-lg font-bold">{index + 1}</span>
            </div>
            <p class="text-xl font-bold text-white leading-tight">{item}</p>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
