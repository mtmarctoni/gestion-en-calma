---
import ContactForm from '@/components/forms/ContactForm.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadContactPage, loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const [site, page] = await Promise.all([loadSiteSettings(), loadContactPage()]);
const errorMessage = Astro.url.searchParams.get('error');

const metadata = buildMetadata({
  seo: page.seo,
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  <section class="relative min-h-screen py-16 md:py-24 overflow-hidden">
    {/* Background image - calming workspace/coffee scene */}
    <div class="absolute inset-0">
      <img 
        src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1920&q=80" 
        alt="" 
        class="w-full h-full object-cover opacity-20"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-brand-background via-brand-background/95 to-brand-blush/20"></div>
    </div>
    
    {/* Decorative elements */}
    <div class="absolute top-20 right-10 w-64 h-64 bg-brand-olive/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-10 w-48 h-48 bg-brand-blush/30 rounded-full blur-3xl"></div>

    <Container class="relative z-10">
      {/* Section header */}
      <div class="text-center max-w-3xl mx-auto mb-16">
        {page.eyebrow && (
          <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-teal/15 text-brand-teal text-xs font-bold tracking-wider uppercase">
            {page.eyebrow}
          </span>
        )}
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-6 leading-tight">{page.title}</h1>
        <p class="text-lg md:text-xl text-brand-text-soft leading-relaxed">{page.intro}</p>
      </div>

      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-start max-w-6xl mx-auto">
        {/* Left column - Contact methods with images */}
        <div class="space-y-6">
          {/* WhatsApp card */}
          <div class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
            <div class="relative h-44 overflow-hidden">
              <img 
                src="https://images.unsplash.com/photo-1611746872915-64382b5c76da?w=600&q=80" 
                alt="WhatsApp"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
              <div class="absolute bottom-4 left-4 w-14 h-14 rounded-2xl bg-green-500 flex items-center justify-center shadow-lg">
                <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-brand-text mb-2">WhatsApp</h3>
              <p class="text-brand-text-soft mb-4">Respuesta rápida en horario laboral</p>
              <Button href={site.whatsappUrl} variant="secondary" target="_blank" rel="noreferrer" class="w-full justify-center">
                Abrir WhatsApp
              </Button>
            </div>
          </div>

          {/* Email card */}
          <div class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
            <div class="relative h-44 overflow-hidden">
              <img 
                src="https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=600&q=80" 
                alt="Email"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
              <div class="absolute bottom-4 left-4 w-14 h-14 rounded-2xl bg-brand-teal flex items-center justify-center shadow-lg">
                <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-brand-text mb-2">Email</h3>
              <p class="text-brand-text-soft mb-4">Para consultas detalladas</p>
              <a 
                href={`mailto:${site.email}`}
                class="block w-full text-center px-6 py-3 rounded-xl border-2 border-brand-teal/30 text-brand-teal font-bold hover:bg-brand-teal hover:text-white transition-colors"
              >
                {site.email}
              </a>
            </div>
          </div>
          
          {/* Trust badges */}
          <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-6 border border-brand-secondary/20">
            <p class="text-sm font-bold text-brand-text mb-4">Por qué contactar:</p>
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-brand-olive/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm text-brand-text-soft">Primera consulta sin compromiso</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-brand-olive/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm text-brand-text-soft">Respuesta en menos de 24h</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-brand-olive/10 flex items-center justify-center">
                  <svg class="w-4 h-4 text-brand-olive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <span class="text-sm text-brand-text-soft">Presupuesto adaptado a tu negocio</span>
              </div>
            </div>
          </div>
        </div>

        {/* Right column - Form */}
        <div class="bg-white rounded-3xl shadow-soft p-8 md:p-10">
          <div class="mb-8">
            <h2 class="text-2xl md:text-3xl font-bold text-brand-text mb-3">{page.formTitle}</h2>
            <p class="text-brand-text-soft leading-relaxed">{page.formIntro}</p>
          </div>
          
          {errorMessage && (
            <div class="rounded-xl border-2 border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700 mb-6">
              {errorMessage}
            </div>
          )}
          
          <form action="/api/contact" class="space-y-5" method="post">
            <input class="hidden" type="text" name="company" autocomplete="off" tabindex="-1" />

            <div class="grid gap-5 md:grid-cols-2">
              <label class="grid gap-2 text-sm font-bold text-brand-text">
                Nombre
                <input 
                  class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" 
                  name="name" 
                  required 
                  type="text" 
                  placeholder="Tu nombre"
                />
              </label>

              <label class="grid gap-2 text-sm font-bold text-brand-text">
                Email
                <input 
                  class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" 
                  name="email" 
                  required 
                  type="email" 
                  placeholder="tu@email.com"
                />
              </label>
            </div>

            <label class="grid gap-2 text-sm font-bold text-brand-text">
              Tipo de negocio
              <input 
                class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" 
                name="business" 
                type="text" 
                placeholder="Ej: Tienda online, consultora, taller..."
              />
            </label>

            <label class="grid gap-2 text-sm font-bold text-brand-text">
              ¿En qué necesitas apoyo?
              <textarea 
                class="min-h-32 rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm resize-y" 
                name="message" 
                required
                placeholder="Cuéntame brevemente tu situación y qué tipo de apoyo buscas..."
              ></textarea>
            </label>

            <div class="pt-4">
              <Button type="submit" class="w-full md:w-auto text-lg px-10 py-4">
                Enviar mensaje
              </Button>
            </div>
            
            <p class="text-xs text-brand-text-muted text-center md:text-left">
              Al enviar, aceptas que te contacte por email o WhatsApp. No comparto tus datos con nadie.
            </p>
          </form>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
