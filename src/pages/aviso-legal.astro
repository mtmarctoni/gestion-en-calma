---
import Container from '@/components/ui/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMetadata } from '@/lib/seo/buildMetadata';
import { loadSiteSettings } from '@/lib/sanity/loaders';
import { env } from '@/lib/utils/env';

const site = await loadSiteSettings();

const metadata = buildMetadata({
  seo: {
    title: `Aviso legal | ${site.siteName}`,
    description: 'Información legal básica del sitio web Gestión en Calma.',
    ogImage: site.seo.ogImage,
  },
  siteName: site.siteName,
  siteUrl: env.siteUrl,
  pathname: Astro.url.pathname,
});
---

<BaseLayout site={site} metadata={metadata}>
  <section class="py-16 md:py-20">
    <Container class="max-w-3xl">
      <h1 class="text-4xl font-bold text-brand-text md:text-5xl">Aviso legal</h1>
      <div class="mt-8 space-y-6 text-base leading-8 text-brand-text-soft">
        <p>Este texto es un punto de partida y debe revisarse con los datos finales de Yolanda antes de publicar el sitio.</p>
        <p>Responsable del sitio: Yolanda, Gestión en Calma.</p>
        <p>Contacto provisional: <a href={`mailto:${site.email}`} class="font-bold text-brand-warm hover:text-brand-text">{site.email}</a></p>
        <p>Actividad: servicios de apoyo administrativo y digital para autónomos y pequeños negocios.</p>
      </div>
    </Container>
  </section>
</BaseLayout>
