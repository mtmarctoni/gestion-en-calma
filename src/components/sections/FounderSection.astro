---
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['founder'];
  founderName?: string;
}

const { data, founderName = 'Yolanda' } = Astro.props;
---

<section class="relative py-24 md:py-32 overflow-hidden bg-brand-teal/5">
  <!-- Background botanical decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-30">
    <img 
      src="https://images.unsplash.com/photo-1463936575829-25148e1db1b8?w=1200&q=80" 
      alt="" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-l from-transparent to-brand-background"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Image column -->
      <div class="relative order-2 lg:order-1">
        <div class="relative max-w-md mx-auto lg:mx-0">
          <!-- Main portrait -->
          <div class="relative aspect-[3/4] rounded-3xl overflow-hidden shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=80" 
              alt={`${founderName} - Fundadora de Gestión en Calma`}
              class="w-full h-full object-cover"
            />
            <!-- Warm overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-brand-terracotta/20 via-transparent to-transparent"></div>
          </div>
          
          <!-- Floating detail image -->
          <div class="absolute -bottom-6 -right-6 w-40 h-40 rounded-2xl overflow-hidden shadow-xl border-4 border-white">
            <img 
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80" 
              alt="Detalle de trabajo en calma"
              class="w-full h-full object-cover"
            />
          </div>
          
          <!-- Decorative accent -->
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-brand-blush/50 rounded-full blur-xl"></div>
          <div class="absolute top-1/2 -left-8 w-16 h-16 bg-brand-olive/30 rounded-full blur-lg"></div>
        </div>
      </div>

      <!-- Content column -->
      <div class="order-1 lg:order-2">
        <span class="inline-block mb-4 px-4 py-2 rounded-full bg-white shadow-sm text-brand-teal text-xs font-bold tracking-wider uppercase">
          Sobre mí
        </span>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-6 leading-tight">
          {data.title}
        </h2>
        
        <div class="space-y-4 text-lg leading-relaxed text-brand-text-soft mb-8">
          {data.body.slice(0, 2).map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        
        <Button href="/sobre-mi/" variant="secondary">Conocer más</Button>
      </div>
    </div>
  </Container>
</section>
