---
import Container from '@/components/ui/Container.astro';

interface Props {
  items: string[];
}

const { items } = Astro.props;

// Checkmark icons in different colors
const checkColors = [
  'text-brand-terracotta',
  'text-brand-teal',
  'text-brand-olive',
];
---

<section class="relative py-12 overflow-hidden">
  <Container>
    <div class="bg-white/80 backdrop-blur-sm rounded-3xl border border-brand-secondary/50 shadow-soft p-8">
      <div class="grid gap-6 md:grid-cols-3">
        {items.map((item, index) => (
          <div class="flex items-center gap-4">
            <!-- Colored checkmark -->
            <div class={`w-10 h-10 rounded-full bg-brand-secondary/50 flex items-center justify-center flex-shrink-0 ${checkColors[index % 3]}`}>
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </div>
            
            <!-- Text -->
            <span class="font-bold text-brand-text">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
