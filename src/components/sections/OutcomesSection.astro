---
import Container from '@/components/ui/Container.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import type { HomePageData } from '@/data/fallbackContent';

interface Props {
  data: HomePageData['outcomes'];
}

const { data } = Astro.props;
---

<section class="bg-brand-secondary/30 py-14 md:py-20">
  <Container>
    <SectionHeading title={data.title} />

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {data.items.map((item) => (
        <div class="surface-card px-6 py-5 text-brand-text-soft font-semibold">
          <span class="mr-3 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-primary text-xs text-brand-text">✓</span>
          {item}
        </div>
      ))}
    </div>
  </Container>
</section>
