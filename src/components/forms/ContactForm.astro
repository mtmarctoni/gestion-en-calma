---
import Button from '@/components/ui/Button.astro';

interface Props {
  title: string;
  intro: string;
}

const { title, intro } = Astro.props;
---

<section class="surface-card p-8 md:p-10">
  <h2 class="text-2xl font-bold text-brand-text md:text-3xl">{title}</h2>
  <p class="mt-4 text-base leading-7 text-brand-text-soft">{intro}</p>

  <form action="/api/contact" class="mt-8 grid gap-5" method="post">
    <input class="hidden" type="text" name="company" autocomplete="off" tabindex="-1" />

    <label class="grid gap-2 text-sm font-bold text-brand-text">
      Nombre
      <input class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" name="name" required type="text" />
    </label>

    <label class="grid gap-2 text-sm font-bold text-brand-text">
      Email
      <input class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" name="email" required type="email" />
    </label>

    <label class="grid gap-2 text-sm font-bold text-brand-text">
      Tipo de negocio
      <input class="rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" name="business" type="text" />
    </label>

    <label class="grid gap-2 text-sm font-bold text-brand-text">
      ¿En qué necesitas apoyo?
      <textarea class="min-h-36 rounded-xl border-2 border-brand-secondary bg-brand-background px-4 py-3 text-base text-brand-text outline-none transition focus:border-brand-primary focus:shadow-warm" name="message" required></textarea>
    </label>

    <div class="pt-2">
      <Button type="submit">Enviar mensaje</Button>
    </div>
  </form>
</section>
