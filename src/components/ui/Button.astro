---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  target?: string;
  rel?: string;
  type?: 'button' | 'submit';
  class?: string;
}

const {
  href,
  variant = 'primary',
  target,
  rel,
  type = 'button',
  class: className = '',
} = Astro.props;

const baseClass =
  'inline-flex items-center justify-center rounded-xl px-6 py-3.5 text-sm font-bold tracking-wide transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-background focus-visible:ring-brand-primary';

const variantClass = {
  primary:
    'bg-brand-primary text-brand-text shadow-warm hover:bg-brand-warm hover:shadow-soft',
  secondary:
    'border-2 border-brand-primary bg-brand-secondary/50 text-brand-text hover:bg-brand-primary hover:text-brand-text shadow-card',
  ghost: 'text-brand-text-soft hover:text-brand-text hover:bg-brand-secondary/30',
}[variant];

const classes = `${baseClass} ${variantClass} ${className}`.trim();
---

{href ? (
  <a class={classes} href={href} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button class={classes} type={type}>
    <slot />
  </button>
)}
