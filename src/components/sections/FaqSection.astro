---
import Container from '@/components/ui/Container.astro';
import type { FAQItem } from '@/data/fallbackContent';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

// FAQ category images
const faqImages = [
  "https://images.unsplash.com/photo-1577563908411-5077b6dc7624?w=400&q=80", // Process
  "https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=400&q=80", // Pricing/money
  "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=400&q=80", // Communication
  "https://images.unsplash.com/photo-1493934558415-9d19f0b2b4d2?w=400&q=80", // Start
];
---

<section class="relative py-24 md:py-32 overflow-hidden">
  {/* Background with subtle texture */}
  <div class="absolute inset-0 bg-brand-olive/5"></div>
  
  {/* Decorative elements */}
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-olive/20 to-transparent"></div>
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-olive/20 to-transparent"></div>

  <Container class="relative z-10">
    {/* Section header */}
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-block mb-4 px-4 py-2 rounded-full bg-brand-olive/15 text-brand-olive text-xs font-bold tracking-wider uppercase">
        FAQ
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-text mb-4">Preguntas frecuentes</h2>
      <p class="text-lg text-brand-text-soft">Respuestas rápidas antes de hablar</p>
    </div>

    {/* FAQ items with images */}
    <div class="max-w-4xl mx-auto space-y-4">
      {items.map((item, index) => (
        <details class="group bg-white rounded-3xl overflow-hidden shadow-soft hover:shadow-warm transition-all duration-300">
          <summary class="list-none cursor-pointer flex items-center gap-6 p-6">
            {/* Thumbnail image */}
            <div class="hidden sm:block w-24 h-24 rounded-2xl overflow-hidden flex-shrink-0">
              <img 
                src={faqImages[index % 4]} 
                alt=""
                class="w-full h-full object-cover"
              />
            </div>
            
            {/* Question */}
            <span class="flex-grow text-lg md:text-xl font-bold text-brand-text">{item.question}</span>
            
            {/* Expand indicator */}
            <div class="w-10 h-10 rounded-full bg-brand-secondary/50 flex items-center justify-center flex-shrink-0 group-open:bg-brand-olive group-open:text-white transition-all">
              <svg class="w-5 h-5 group-open:rotate-45 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </div>
          </summary>
          
          {/* Answer */}
          <div class="px-6 pb-6">
            <div class="pl-0 sm:pl-30">
              <p class="text-brand-text-soft leading-relaxed text-lg max-w-2xl">{item.answer}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
    
    {/* CTA */}
    <div class="mt-12 text-center">
      <p class="text-brand-text-soft mb-4">¿Tienes otras preguntas?</p>
      <a 
        href="/contacto/" 
        class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-brand-olive text-white font-bold shadow-warm hover:shadow-panel transition-all hover:scale-105"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Escríbenos
      </a>
    </div>
  </Container>
</section>
